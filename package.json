{
  "name": "moodinator",
  "main": "expo-router/entry",
  "version": "1.2.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios",
    "web": "expo start --web",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "expo lint",
    "prebuild": "bun scripts/bump-version.js",
    "build": "eas build --platform android --profile preview --local",
    "build:preview": "eas build --platform android --profile preview --local",
    "build:production": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.4.18",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "expo": "~55.0.5",
    "expo-av": "~16.0.8",
    "expo-background-task": "~55.0.10",
    "expo-blur": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linking": "~55.0.8",
    "expo-local-authentication": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-sharing": "~55.0.14",
    "expo-splash-screen": "~55.0.12",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-task-manager": "~55.0.10",
    "expo-web-browser": "~55.0.10",
    "install": "^0.13.0",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-haptic-feedback": "^2.3.3",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "sonner": "^2.0.7",
    "sonner-native": "^0.25.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "8.57.0",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-chart-kit",
          "expo-av",
          "date-fns-tz",
          "install",
          "react-native-vector-icons"
        ]
      }
    }
  },
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ],
  "patchedDependencies": {
    "expo-av@16.0.8": "patches/expo-av@16.0.8.patch"
  }
}
