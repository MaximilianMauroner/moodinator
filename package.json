{
  "name": "moodinator",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "prebuild": "bun scripts/bump-version.js",
    "build": "eas build --platform android --profile preview --local"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/__tests__/setup.ts",
      "<rootDir>/__tests__/db/mockClient.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@db/(.*)$": "<rootDir>/db/$1",
      "^@assets/(.*)$": "<rootDir>/assets/$1"
    },
    "collectCoverageFrom": [
      "db/**/*.ts",
      "!db/**/*.d.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.4.18",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "expo": "^55.0.0",
    "expo-av": "~16.0.8",
    "expo-background-task": "~55.0.8",
    "expo-blur": "~55.0.8",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.8",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-image-manipulator": "~55.0.9",
    "expo-image-picker": "~55.0.9",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-localization": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.2",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.10",
    "expo-splash-screen": "~55.0.9",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-task-manager": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "install": "^0.13.0",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-haptic-feedback": "^2.3.3",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.17",
    "toastify-react-native": "^7.2.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "8.57.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.9",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-chart-kit",
          "expo-av",
          "date-fns-tz",
          "install",
          "react-native-vector-icons"
        ]
      }
    }
  },
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ]
}
