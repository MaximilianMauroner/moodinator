{
  "expo": {
    "name": "Moodinator",
    "slug": "moodinator",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icons/app-icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lab4code.moodinator",
      "infoPlist": {
        "UIFileSharingEnabled": false,
        "LSSupportsOpeningDocumentsInPlace": false,
        "UIBackgroundModes": [
          "fetch"
        ]
      }
    },
    "androidStatusBar": {
      "translucent": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icons/adaptive-foreground.png",
        "backgroundColor": "#9EAD7F"
      },
      "package": "com.lab4code.moodinator",
      "permissions": [
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app-icons/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icons/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FAF8F4",
          "dark": {
            "image": "./assets/images/app-icons/splash-icon-dark.png",
            "backgroundColor": "#24302A"
          }
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": true,
          "android": {
            "enableFTS": false,
            "useSQLCipher": false
          },
          "ios": {
            "customBuildFlags": [
              "-DSQLITE_ENABLE_DBSTAT_VTAB=1 -DSQLITE_ENABLE_SNAPSHOT=1"
            ]
          }
        }
      ],
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "pickFirst": [
                "lib/x86/libc++_shared.so",
                "lib/x86_64/libc++_shared.so",
                "lib/arm64-v8a/libc++_shared.so",
                "lib/armeabi-v7a/libc++_shared.so"
              ]
            }
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icons/notification-icon.png",
          "color": "#5B8A5B",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-background-task",
      "expo-task-manager",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "427d083c-0bc1-4065-83cc-32d490e8cc06"
      }
    }
  }
}
